package com.sangfor.specialasset.proxy.function;


import com.sangfor.alphasecurity.formats.avro.SpecialAsset;
import com.sangfor.specialasset.common.function.KeyValueUtil;
import com.sangfor.specialasset.common.model.LightAsset;
import com.sangfor.specialasset.common.model.MessageState;
import com.sangfor.specialasset.proxy.constant.Config;
import com.sangfor.specialasset.proxy.model.ProxyEvent;
import org.apache.flink.api.common.state.MapState;
import org.apache.flink.api.common.state.MapStateDescriptor;
import org.apache.flink.api.common.state.StateTtlConfig;
import org.apache.flink.api.common.state.ValueState;
import org.apache.flink.api.common.state.ValueStateDescriptor;
import org.apache.flink.api.common.time.Time;
import org.apache.flink.api.common.typeinfo.Types;
import org.apache.flink.configuration.Configuration;
import org.apache.flink.streaming.api.functions.KeyedProcessFunction;
import org.apache.flink.util.Collector;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

import java.util.ArrayList;
import java.util.List;
import java.util.Map;
import java.util.Optional;

import static com.sangfor.alphasecurity.config.CustomOptions.ASSET_SEND_FRE;
import static com.sangfor.alphasecurity.config.CustomOptions.ENABLE_INTERNET_PROXY;
import static com.sangfor.alphasecurity.config.CustomOptions.RETAIN_DAYS;
import static com.sangfor.specialasset.common.constant.Config.INNER_IP_TAG;
import static com.sangfor.specialasset.common.constant.Config.OUTER_IP_TAG;
import static com.sangfor.specialasset.common.model.SourceType.DOMAIN;
import static com.sangfor.specialasset.common.model.SourceType.HOST;
import static com.sangfor.specialasset.common.model.SourceType.HOST_DST_MISMATCH;
import static com.sangfor.specialasset.common.model.SourceType.UA;
import static com.sangfor.specialasset.common.model.SourceType.UA_BY_PROXY;
import static com.sangfor.specialasset.common.model.SourceType.XFF;

public class SimpleProxyStateFunction extends KeyedProcessFunction<Integer, ProxyEvent, SpecialAsset> {
private static final Logger LOGGER = LoggerFactory.getLogger(SimpleProxyStateFunction.class);

protected transient MapState<String, LightAsset> storeState;
protected transient MapState<String, Boolean> alertSentState;

private int RETAIN_DAY = Config.PROXY_VALID_DAY;
private int SEND_RETAIN_DAY = Config.SEND_FRQ;
private boolean enableInternetProxy = false; // 互联网代理检测开关

private transient ValueState<Long> lastCheckTimeState;
private transient ValueState<Integer> lastInc;

//CHECK_INTERVAL_MS检查存量数据 正常情况下因为增量数据只要超了就会删除 因此总量遍历可以控制
private static final long CHECK_INTERVAL_MS = 60 * 1000 * 30;

//增量数据超过CHECK_INTERVAL_NUM 此时清理一波多余数据。
private static final long CHECK_INTERVAL_NUM = 30 * 1000;

public SimpleProxyStateFunction(com.sangfor.alphasecurity.config.Configuration configuration) {
if (configuration == null) {
return;
}
RETAIN_DAY = configuration.getInteger(RETAIN_DAYS) > 0 ? configuration.getInteger(
RETAIN_DAYS) : Config.PROXY_VALID_DAY;
SEND_RETAIN_DAY = configuration.getInteger(ASSET_SEND_FRE) > 0 ? configuration.getInteger(
ASSET_SEND_FRE) : Config.SEND_FRQ;
enableInternetProxy = configuration.getBoolean(ENABLE_INTERNET_PROXY);
}

@Override
public void open(Configuration parameters) {
StateTtlConfig ttl = StateTtlConfig.newBuilder(Time.days(this.RETAIN_DAY))
.setUpdateType(StateTtlConfig.UpdateType.OnCreateAndWrite)
.setStateVisibility(StateTtlConfig.StateVisibility.NeverReturnExpired)
// 避免每次 state get/put 都触发增量 TTL 清理，降低热点路径 CPU。
.disableCleanupInBackground()
.build();

MapStateDescriptor<String, LightAsset> storeDesc = new MapStateDescriptor<>("proxyStore", Types.STRING, Types.POJO(LightAsset.class));
storeDesc.enableTimeToLive(ttl);
storeState = getRuntimeContext().getMapState(storeDesc);

MapStateDescriptor<String, Boolean> alertSentDesc = new MapStateDescriptor<>("proxyAlertSentState", Types.STRING, Types.BOOLEAN);
StateTtlConfig sendTTL = StateTtlConfig.newBuilder(Time.days(this.SEND_RETAIN_DAY))
.setUpdateType(StateTtlConfig.UpdateType.OnCreateAndWrite)
.setStateVisibility(StateTtlConfig.StateVisibility.NeverReturnExpired)
.disableCleanupInBackground()
.build();
alertSentDesc.enableTimeToLive(sendTTL);
alertSentState = getRuntimeContext().getMapState(alertSentDesc);

ValueStateDescriptor<Long> lastCheckDesc = new ValueStateDescriptor<>("lastCheckTime", Long.class);
lastCheckTimeState = getRuntimeContext().getState(lastCheckDesc);

ValueStateDescriptor<Integer> lastNumDesc = new ValueStateDescriptor<>("lastNum", Types.INT);
lastInc = getRuntimeContext().getState(lastNumDesc);
}


public boolean isValidEvent(ProxyEvent event) {
if (event.getDetectionMethodCode() == XFF.getValue()) {
return event.getSrcIpTag() == INNER_IP_TAG;
}
if (event.getDetectionMethodCode() == UA.getValue()) {
return event.getSrcIpTag() == INNER_IP_TAG && event.getDstIpTag() == INNER_IP_TAG;

}
if (event.getDetectionMethodCode() == DOMAIN.getValue()) {
return event.getDstIpTag() == INNER_IP_TAG;
}
if (event.getDetectionMethodCode() == HOST.getValue()) {
return event.getDstIpTag() == INNER_IP_TAG;
}
if (event.getDetectionMethodCode() == HOST_DST_MISMATCH.getValue()) {
return event.getInnerTag() == INNER_IP_TAG;
}
return false;
}

@Override
public void processElement(ProxyEvent newEvent, KeyedProcessFunction<Integer, ProxyEvent, SpecialAsset>.Context context,
Collector<SpecialAsset> collector) {
try {
if (!isValidEvent(newEvent)) {
return;
}
String key = KeyValueUtil.proxyKey(newEvent);
Boolean hasSend = Optional.ofNullable(alertSentState.get(key)).orElse(Boolean.FALSE);
if (hasSend) {
return; // 已经告警过的key不再重复告警
}
if (!newEvent.hasValidUuid()) {
return;
}
LightAsset lightAsset = storeState.get(key);
if (lightAsset == null) {
lightAsset = new LightAsset();
Integer curNum = Optional.ofNullable(lastInc.value()).orElse(0);
lastInc.update(curNum + 1);
}
lightAsset.Update(newEvent);

if (lightAsset.getDetectionMethod() == UA.getValue()) {
emitAndMark(lightAsset, collector, key, MessageState.INSERT.getValue());
// 互联网代理检测 - 可通过配置项 evict.data.asset.special_data.enable_internet_proxy 开关控制
if (enableInternetProxy) {
lightAsset.setDetectionMethod(UA_BY_PROXY.getValue());
emitAndMarkNet(lightAsset, collector, key, MessageState.INSERT.getValue());
}
return;
}

if (lightAsset.getDetectionMethod() == HOST_DST_MISMATCH.getValue()) {
emitAndMark(lightAsset, collector, key, MessageState.UPSERT.getValue());
return;
}

        boolean emitted = false;
        if (lightAsset.getCount() >= Config.COMMON_LIMIT) {
            if (HOST.getValue() == lightAsset.getDetectionMethod()) {
                if (lightAsset.getValidHostCount() >= Config.MIN_VALID_HOST_COUNT) {
                    emitted = emitAndMark(lightAsset, collector, key, MessageState.UPSERT.getValue());
                }
            } else if (XFF.getValue() == lightAsset.getDetectionMethod() && newEvent.getXffClientIpTag() == OUTER_IP_TAG) {
                emitted = emitAndMark(lightAsset, collector, key, MessageState.UPSERT.getValue());
                // 互联网代理检测 - 可通过配置项 evict.data.asset.special_data.enable_internet_proxy 开关控制
                if (enableInternetProxy) {
                    lightAsset.setDetectionMethod(UA_BY_PROXY.getValue());
                    emitted = emitAndMarkNet(lightAsset, collector, key, MessageState.UPSERT.getValue()) || emitted;
                }
            } else {
                emitted = emitAndMark(lightAsset, collector, key, MessageState.UPSERT.getValue());
            }
        }
        if (emitted) {
            storeState.remove(key);
            return;
        }
        storeState.put(key, lightAsset);


Integer curNum = Optional.ofNullable(lastInc.value()).orElse(0);
if (curNum > CHECK_INTERVAL_NUM) {
removeRedundantData();
return;
}

Long lastCheckTime = lastCheckTimeState.value();
long currentTime = context.timerService().currentProcessingTime();
if (lastCheckTime == null || currentTime - lastCheckTime > CHECK_INTERVAL_MS) {
context.timerService().registerProcessingTimeTimer(currentTime + CHECK_INTERVAL_MS);
lastCheckTimeState.update(currentTime);
}

} catch (Exception e) {
LOGGER.warn("err in", e);
}
}

public void onTimer(long timestamp, OnTimerContext ctx, Collector<SpecialAsset> out) throws Exception {
removeRedundantData();
}

private void removeRedundantData() throws Exception {
LOGGER.debug("Timer triggered Starting cleanup check.");

int stateSize = 0;


for (Map.Entry<String, LightAsset> ignored : storeState.entries()) {
stateSize++;
}

final int MAX_STATE_SIZE = 10_0000;
if (stateSize >= MAX_STATE_SIZE) {
LOGGER.info("State size ({}) reached limit. Evicting random key", stateSize);
List<String> randomKey = new ArrayList<>();
int val = 0;
int retailData = stateSize - MAX_STATE_SIZE;
for (Map.Entry<String, LightAsset> entry : storeState.entries()) {
if (val < retailData) {
val++;
randomKey.add(entry.getKey());
}
}
for (String key : randomKey) {
storeState.remove(key);
alertSentState.remove(key);
}
}
lastCheckTimeState.clear();
lastInc.update(0);
}


private boolean emitAndMark(LightAsset lightAsset,
Collector<SpecialAsset> collector,
String key,
int messageState) throws Exception {
Optional<SpecialAsset> optionalAsset = lightAsset.buildProxyEvent();
if (optionalAsset.isEmpty()) {
return false;
}
SpecialAsset specialAsset = optionalAsset.get();
specialAsset.setState(messageState);
collector.collect(specialAsset);
alertSentState.put(key, true);
return true;
}

private boolean emitAndMarkNet(LightAsset lightAsset,
Collector<SpecialAsset> collector,
String key,
int messageState) throws Exception {
Optional<SpecialAsset> optionalAsset = lightAsset.buildNetProxyEvent();
if (optionalAsset.isEmpty()) {
return false;
}
SpecialAsset specialAsset = optionalAsset.get();
specialAsset.setState(messageState);
collector.collect(specialAsset);
alertSentState.put(key, true);
return true;
}


}
